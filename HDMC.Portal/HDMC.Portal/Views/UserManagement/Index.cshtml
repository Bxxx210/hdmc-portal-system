@model List<HDMC.Portal.Models.UserManagementModel>

@{
    ViewBag.Title = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h4>User Management</h4>
        </div>

        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }

            <form method="get"
                  class="row g-2 mb-3">

                <div class="col-md-8">
                    <input type="text"
                           name="searchText"
                           value="@ViewBag.SearchText"
                           class="form-control"
                           placeholder="Search user, company, or role" />
                </div>

                <div class="col-md-4">
                    <button type="submit"
                            class="btn btn-primary">
                        Search
                    </button>

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary">
                        Clear
                    </a>
                </div>

            </form>

            <div class="mb-3">

                <a href="@Url.Action(
                     "UserManagement",
                     "Create")"
                   class="btn btn-success">

                    Create User

                </a>

            </div>

            <table class="table table-bordered">

                <thead>

                    <tr>
                        <th>User ID</th>
                        <th>User Name</th>
                        <th>Company</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.UserId</td>

                            <td>@item.UserName</td>

                            <td>@item.Company</td>

                            <td>@item.RoleName</td>

                            <td>
                                @(item.IsActive
                                    ? "Active"
                                    : "Inactive")
                            </td>

                            <td>
                                <a href="@Url.Action(
                                             "Edit",
                                             "UserManagement",
                                             new
                                             {
                                                 id = item.UserId
                                             })"
                                   class="btn btn-primary btn-sm">

                                    Edit

                                </a>

                                <a href="@Url.Action(
                                             "ResetPassword",
                                             "UserManagement",
                                             new
                                             {
                                                 id = item.UserId
                                             })"
                                   class="btn btn-warning btn-sm">

                                    Reset Password

                                </a>

                                <form method="post"
                                      action="@Url.Action("SetActive", "UserManagement")"
                                      class="d-inline">

                                    <input type="hidden"
                                           name="userId"
                                           value="@item.UserId" />

                                    <input type="hidden"
                                           name="isActive"
                                           value="@(!item.IsActive)" />

                                    <button type="submit"
                                            class="btn btn-secondary btn-sm">
                                        @(item.IsActive
                                            ? "Deactivate"
                                            : "Activate")
                                    </button>

                                </form>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
