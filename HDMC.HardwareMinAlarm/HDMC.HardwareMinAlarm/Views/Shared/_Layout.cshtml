<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - HDMC Hardware</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="hardware-nav">
        <a href="@Url.Action("Index", "Home")" class="hardware-brand">
            <span class="hardware-brand-mark">HD</span>
            <span>HDMC Hardware</span>
        </a>

        <span class="hardware-context">
            @Session["UserName"]
            @if (Session["Company"] != null)
            {
                <text> / @Session["Company"]</text>
            }
        </span>

        <div class="hardware-nav-links">
            @if (Session["RoleId"] != null &&
                 (Session["RoleId"].ToString() == "1" ||
                  Session["RoleId"].ToString() == "2"))
            {
                <a href="@Url.Action("Index", "Menu")" class="hardware-nav-link">Menu</a>
                <a href="@Url.Action("Index", "UploadHistory")" class="hardware-nav-link">Upload History</a>
            }
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
