@{
    ViewBag.Title = "Hardware Min Alarm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main class="scan-page">

    <section class="scan-header">

        <div>
            <div class="scan-eyebrow">HDMC Hardware Min Alarm</div>
            <h1>Scan Part</h1>
        </div>

        <div class="scan-user-panel">
            <div>
                <span>User</span>
                <strong>@Session["UserName"]</strong>
            </div>
            <div>
                <span>Company</span>
                <strong>@Session["Company"]</strong>
            </div>
        </div>

    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success scan-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger scan-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger scan-alert">
            @ViewBag.ErrorMessage
        </div>
    }

    <section class="scan-panel">

        <form method="post"
              class="scan-form">

            <label for="txtPartNumber">
                Part Number
            </label>

            <div class="scan-input-row">

                <input type="text"
                       id="txtPartNumber"
                       name="partNumber"
                       class="form-control scan-input"
                       autocomplete="off"
                       autofocus />

                <button type="submit"
                        class="btn btn-primary scan-search-button">

                    Search

                </button>

            </div>

        </form>

    </section>

    @if (ViewBag.PartNumber != null)
    {
        <section class="part-panel">

            <div class="part-title-row">
                <div>
                    <span>Part</span>
                    <strong>@ViewBag.PartNumber</strong>
                </div>
                <div>
                    <span>Status</span>
                    <strong>@(string.IsNullOrWhiteSpace(ViewBag.PartStatus as string) ? "-" : ViewBag.PartStatus)</strong>
                </div>
            </div>

            <div class="part-description">
                @ViewBag.PartDescription
            </div>

            <dl class="part-detail-grid">
                <div>
                    <dt>From Location</dt>
                    <dd>@(string.IsNullOrWhiteSpace(ViewBag.LocationName as string) ? "-" : ViewBag.LocationName)</dd>
                </div>
                <div>
                    <dt>Last User</dt>
                    <dd>@(string.IsNullOrWhiteSpace(ViewBag.UserStamp as string) ? "-" : ViewBag.UserStamp)</dd>
                </div>
            </dl>

        </section>

        <section class="status-panel">

            <h2>Move To Location</h2>

            <form method="post"
                  action="@Url.Action(
                      "SaveStatus",
                      "Home")">

                <input type="hidden"
                       name="partNumber"
                       value="@ViewBag.PartNumber" />

                <div class="status-button-grid">

                    <input type="radio"
                           id="status100"
                           name="statusCode"
                           value="100"
                           class="status-radio" />

                    <label for="status100"
                           class="status-action-button">

                        <span>100</span>
                        Request Replenish

                    </label>

                    <input type="radio"
                           id="status200"
                           name="statusCode"
                           value="200"
                           class="status-radio" />

                    <label for="status200"
                           class="status-action-button">

                        <span>200</span>
                        Kanban from MFG

                    </label>

                    <input type="radio"
                           id="status300"
                           name="statusCode"
                           value="300"
                           class="status-radio" />

                    <label for="status300"
                           class="status-action-button">

                        <span>300</span>
                        Stock min &lt;10 days

                    </label>

                    <input type="radio"
                           id="status400"
                           name="statusCode"
                           value="400"
                           class="status-radio" />

                    <label for="status400"
                           class="status-action-button">

                        <span>400</span>
                        Location discrepancy

                    </label>

                    <input type="radio"
                           id="status500"
                           name="statusCode"
                           value="500"
                           class="status-radio" />

                    <label for="status500"
                           class="status-action-button">

                        <span>500</span>
                        Check Shipment ETA

                    </label>

                    <input type="radio"
                           id="status600"
                           name="statusCode"
                           value="600"
                           class="status-radio" />

                    <label for="status600"
                           class="status-action-button">

                        <span>600</span>
                        ETA Today

                    </label>

                    <input type="radio"
                           id="status900"
                           name="statusCode"
                           value="900"
                           class="status-radio" />

                    <label for="status900"
                           class="status-action-button status-complete-button">

                        <span>900</span>
                        Replenish Completed

                    </label>

                </div>

                <button type="submit"
                        class="btn btn-success save-status-button">

                    Save Status

                </button>

            </form>

        </section>
    }

</main>

<script>
    window.onload = function () {
        var partTextbox =
            document.getElementById("txtPartNumber");

        if (partTextbox) {
            partTextbox.focus();
        }
    };
</script>
