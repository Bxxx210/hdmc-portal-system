@using System.Linq
@model HDMC.HardwareMinAlarm.Models.UploadResultModel
@{
    ViewBag.Title = "Upload Item Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h4>Upload Item Master</h4>
        </div>

        <div class="card-body">

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form method="post"
                  enctype="multipart/form-data">

                <div class="mb-3">

                    <input type="file"
                           name="file"
                           class="form-control"
                           accept=".xlsx,.csv" />

                </div>

                <button type="submit"
                        class="btn btn-primary">

                    Upload

                </button>

                <a href="@Url.Action("Template", "Upload")"
                   class="btn btn-secondary">

                    Download Template

                </a>

            </form>

            @if (Model != null)
            {
                <hr />

                <p>
                    <strong>Total:</strong>
                    @Model.TotalRows
                </p>

                <p>
                    <strong>Success:</strong>
                    @Model.SuccessRows
                </p>

                <p>
                    <strong>Failed:</strong>
                    @Model.FailedRows
                </p>

                <p>
                    <strong>Error:</strong>
                    @Model.ErrorMessage
                    @if (Model.Errors != null &&
                     Model.Errors.Any())
                    {
                        <hr />

                        <ul class="text-danger">

                            @foreach (var error in Model.Errors)
                            {
                                <li>@error</li>
                            }

                        </ul>
                    }
                </p>

            }

        </div>

    </div>

</div>
