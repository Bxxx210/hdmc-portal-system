@using System.Linq
@model HDMC.HardwareMinAlarm.Models.UploadResultModel
@{
    ViewBag.Title = "Upload Item Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1 class="page-title">Upload Item Master</h1>
            <p class="page-subtitle">Import item master data from Excel and review the result immediately.</p>
        </div>
    </div>

    <div class="surface-panel">
        <div class="panel-body upload-grid">

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form method="post"
                  enctype="multipart/form-data"
                  class="row g-3 align-items-end">

                <div class="col-lg-8">
                    <label class="form-label">Excel File</label>
                    <input type="file"
                           name="file"
                           class="form-control"
                           accept=".xlsx,.xls,.csv" />
                </div>

                <div class="col-lg-4">
                    <button type="submit"
                            class="btn btn-primary w-100">
                        Upload
                    </button>
                </div>
            </form>

            @if (Model != null)
            {
                <div class="section-divider"></div>

                <div class="result-summary">
                    <div class="summary-box">
                        <span class="summary-label">Total</span>
                        <span class="summary-value">@Model.TotalRows</span>
                    </div>
                    <div class="summary-box">
                        <span class="summary-label">Success</span>
                        <span class="summary-value">@Model.SuccessRows</span>
                    </div>
                    <div class="summary-box">
                        <span class="summary-label">Failed</span>
                        <span class="summary-value">@Model.FailedRows</span>
                    </div>
                </div>

                if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        @Model.ErrorMessage
                    </div>
                }

                if (Model.Errors != null &&
                    Model.Errors.Any())
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <ul class="mb-0 ps-3">
                            @foreach (var error in Model.Errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }
            }

        </div>
    </div>
</div>
