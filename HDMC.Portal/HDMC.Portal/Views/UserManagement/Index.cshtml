@model List<HDMC.Portal.Models.UserManagementModel>

@{
    ViewBag.Title = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h4>User Management</h4>
        </div>

        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            <div class="mb-3">

                <a href="@Url.Action(
                     "UserManagement",
                     "Create")"
                   class="btn btn-success">

                    Create User

                </a>

            </div>

            <table class="table table-bordered">

                <thead>

                    <tr>
                        <th>User ID</th>
                        <th>User Name</th>
                        <th>Company</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.UserId</td>

                            <td>@item.UserName</td>

                            <td>@item.Company</td>

                            <td>@item.RoleName</td>

                            <td>
                                @(item.IsActive
                                    ? "Active"
                                    : "Inactive")
                            </td>

                            <td>
                                <a href="@Url.Action(
                                             "ResetPassword",
                                             "UserManagement",
                                             new
                                             {
                                                 id = item.UserId
                                             })"
                                   class="btn btn-warning btn-sm">

                                    Reset Password

                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
