@using System.Linq
@model HDMC.HardwareMinAlarm.Models.ItemMasterSearchViewModel

@{
    ViewBag.Title = "Item Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="item-master-wrapper">
    <div class="item-master-heading">
        <div>
            <div class="menu-eyebrow">Hardware Min Alarm</div>
            <h1 class="menu-title">Item Master</h1>
            <div class="menu-hint">
                Manage parts for company <strong>@Session["Company"]</strong>.
                The table previews up to 200 rows. Export downloads the complete data set.
            </div>
        </div>
        <a href="@Url.Action("Export", "ItemMaster")"
           class="btn btn-outline-primary">
            Export Excel
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="item-master-card">
        <div class="item-master-toolbar">
            <form method="get"
                  class="item-master-search">
                <input type="text"
                       name="searchText"
                       value="@Model.SearchText"
                       class="form-control"
                       placeholder="Search part no. or description" />
                <button type="submit"
                        class="btn btn-primary">
                    Search
                </button>
                <a href="@Url.Action("Index", "ItemMaster")"
                   class="btn btn-light">
                    Clear
                </a>
            </form>

            <div class="item-master-count">
                Showing <strong>@Model.Items.Count</strong>
                of <strong>@Model.TotalCount</strong> record(s)
            </div>
        </div>

        <div class="item-master-table-wrapper">
            @if (Model.TotalCount > Model.Items.Count)
            {
                <div class="item-master-preview-note">
                    Preview limited to the first @Model.Items.Count record(s).
                    Use Export Excel to review the complete data set.
                </div>
            }

            <form method="post"
                  action="@Url.Action("Delete", "ItemMaster")"
                  onsubmit="return confirm('Delete selected part(s)?');">
                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="searchText"
                       value="@Model.SearchText" />

                <div class="item-master-actions">
                    <button type="submit"
                            class="btn btn-outline-danger btn-sm">
                        Delete Selected
                    </button>
                </div>

                <table class="table item-master-table">
                    <thead>
                        <tr>
                            <th style="width: 48px;">
                                <input type="checkbox"
                                       id="selectAll" />
                            </th>
                            <th>Company</th>
                            <th>Part No.</th>
                            <th>Description</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox"
                                           name="selectedParts"
                                           value="@item.Part"
                                           class="part-checkbox" />
                                </td>
                                <td>@item.Company</td>
                                <td>@item.Part</td>
                                <td>@item.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!Model.Items.Any())
                {
                    <div class="alert alert-info">
                        No item master records found
                    </div>
                }

            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        var selectAll =
            document.getElementById("selectAll");

        var checkboxes =
            document.querySelectorAll(".part-checkbox");

        if (selectAll) {
            selectAll.addEventListener("change", function () {
                for (var i = 0; i < checkboxes.length; i++) {
                    checkboxes[i].checked = selectAll.checked;
                }
            });
        }
    })();
</script>
