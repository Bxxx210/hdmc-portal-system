@model List<HDMC.Portal.Models.UserManagementModel>
@{
    ViewBag.Title = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .um-wrapper {
        max-width: 1100px;
        margin: 40px auto;
        padding: 0 24px;
    }

    .um-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .um-page-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: #1e293b;
    }

    .btn-create {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #1a56db;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
        text-decoration: none;
        transition: background 0.2s;
        box-shadow: 0 2px 8px rgba(26,86,219,0.2);
    }

        .btn-create:hover {
            background: #1646b8;
            text-decoration: none;
            color: #fff;
        }

    .um-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }

    .um-card-head {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .search-input {
        flex: 1;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 9px 14px;
        font-size: 14px;
        color: #1e293b;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
    }

        .search-input:focus {
            border-color: #1a56db;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
        }

        .search-input::placeholder {
            color: #cbd5e1;
        }

    .btn-search {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #1a56db;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 14px;
        font-weight: 500;
        color: #fff;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background 0.2s;
        white-space: nowrap;
    }

        .btn-search:hover {
            background: #1646b8;
        }

    .btn-clear {
        display: flex;
        align-items: center;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 9px 14px;
        font-size: 14px;
        color: #64748b;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        transition: background 0.2s, border-color 0.2s;
        white-space: nowrap;
    }

        .btn-clear:hover {
            background: #f1f5f9;
            text-decoration: none;
            color: #1e293b;
        }

    .um-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

        .um-table thead tr {
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
        }

        .um-table th {
            padding: 12px 16px;
            font-size: 11px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 500;
            text-align: left;
        }

        .um-table td {
            padding: 13px 16px;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .um-table tbody tr:last-child td {
            border-bottom: none;
        }

        .um-table tbody tr:hover td {
            background: #fafbff;
        }

    .badge-active {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        background: #dcfce7;
        color: #15803d;
    }

    .badge-inactive {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        background: #f1f5f9;
        color: #94a3b8;
    }

    .action-group {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.15s;
        white-space: nowrap;
    }

        .btn-action.edit {
            background: #eff6ff;
            color: #1a56db;
            border-color: #bfdbfe;
        }

            .btn-action.edit:hover {
                background: #dbeafe;
                text-decoration: none;
            }

        .btn-action.reset {
            background: #fffbeb;
            color: #d97706;
            border-color: #fde68a;
        }

            .btn-action.reset:hover {
                background: #fef3c7;
                text-decoration: none;
            }

        .btn-action.toggle-active {
            background: #f0fdf4;
            color: #16a34a;
            border-color: #bbf7d0;
        }

            .btn-action.toggle-active:hover {
                background: #dcfce7;
            }

        .btn-action.toggle-inactive {
            background: #f8fafc;
            color: #64748b;
            border-color: #e2e8f0;
        }

            .btn-action.toggle-inactive:hover {
                background: #f1f5f9;
            }

    .alert-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #15803d;
        margin-bottom: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .alert-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #b91c1c;
        margin-bottom: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="um-wrapper">

    <div class="um-page-header">
        <div class="um-page-title">User Management</div>
        <a href="@Url.Action("Create", "UserManagement")" class="btn-create">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Create User
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success" style="margin-bottom:16px; border-radius:8px;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><polyline points="20 6 9 17 4 12" /></svg>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error" style="margin-bottom:16px; border-radius:8px;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="um-card">
        <div class="um-card-head">
            <form method="get" style="display:flex; align-items:center; gap:8px; flex:1; margin:0;">
                <input type="text"
                       name="searchText"
                       value="@ViewBag.SearchText"
                       class="search-input"
                       placeholder="ค้นหา User, Company หรือ Role..." />
                <button type="submit" class="btn-search">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    Search
                </button>
                <a href="@Url.Action("Index")" class="btn-clear">Clear</a>
            </form>
        </div>

        <table class="um-table">
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>User Name</th>
                    <th>Company</th>
                    <th>Application</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.UserId</td>
                        <td>@item.UserName</td>
                        <td style="font-size:13px; color:#64748b;">@item.Companies</td>
                        <td style="font-size:13px; color:#64748b;">@item.Applications</td>
                        <td>@item.RoleName</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="action-group">
                                <a href="@Url.Action("Edit", "UserManagement", new { id = item.UserId })"
                                   class="btn-action edit">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                    Edit
                                </a>
                                <a href="@Url.Action("ResetPassword", "UserManagement", new { id = item.UserId })"
                                   class="btn-action reset">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                                    Reset Password
                                </a>
                                <form method="post" action="@Url.Action("SetActive", "UserManagement")" style="margin:0;">
                                    <input type="hidden" name="userId" value="@item.UserId" />
                                    <input type="hidden" name="isActive" value="@(!item.IsActive)" />
                                    <button type="submit" class="btn-action @(item.IsActive ? "toggle-active" : "toggle-inactive")">
                                        @if (item.IsActive)
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.36 6.64A9 9 0 1 1 5.64 5.64" /><path d="M12 2v10" /></svg>
                                            <text>Deactivate</text>
                                        }
                                        else
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                                            <text>Activate</text>
                                        }
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>