@model List<HDMC.Portal.Models.UserManagementModel>

@{
    ViewBag.Title = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1 class="page-title">User Management</h1>
            <p class="page-subtitle">Manage portal access, company mapping, and password reset flow.</p>
        </div>
        <a href="@Url.Action(
             "UserManagement",
             "Create")"
           class="btn btn-success">
            Create User
        </a>
    </div>

    <div class="surface-panel">
        <div class="panel-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            <div class="table-shell">
            <table class="table table-enterprise table-bordered">

                <thead>

                    <tr>
                        <th>User ID</th>
                        <th>User Name</th>
                        <th>Company</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.UserId</td>

                            <td>@item.UserName</td>

                            <td>@item.Company</td>

                            <td>@item.RoleName</td>

                            <td>
                                <span class="status-chip @(item.IsActive ? "is-active" : string.Empty)">
                                    @(item.IsActive
                                        ? "Active"
                                        : "Inactive")
                                </span>
                            </td>

                            <td>
                                <a href="@Url.Action(
                                             "ResetPassword",
                                             "UserManagement",
                                             new
                                             {
                                                 id = item.UserId
                                             })"
                                   class="btn btn-warning btn-sm">

                                    Reset Password

                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>
            </div>

        </div>

    </div>
</div>
