@{
    ViewBag.Title = "Hardware Min Alarm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">

            <div class="d-flex justify-content-between">

                <div>
                    <strong>User:</strong>
                    @Session["UserName"]
                </div>

                <div>
                    <strong>Company:</strong>
                    @Session["Company"]
                </div>

            </div>

        </div>

        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">

                    @TempData["SuccessMessage"]

                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">

                    @TempData["ErrorMessage"]

                </div>
            }

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form method="post">

                <div class="mb-3">

                    <label>
                        Scan Part Number
                    </label>

                    <input type="text"
                           id="txtPartNumber"
                           name="partNumber"
                           class="form-control form-control-lg"
                           autofocus />

                </div>

                <button class="btn btn-primary btn-lg w-100">
                    Search
                </button>

            </form>

            @if (ViewBag.PartNumber != null)
            {
                <hr />

                <div class="mt-3">

                    <p>
                        <strong>Part:</strong>
                        @ViewBag.PartNumber
                    </p>

                    <p>
                        <strong>Description:</strong>
                        @ViewBag.PartDescription
                    </p>

                    <p>
                        <strong>Current Status:</strong>
                        @ViewBag.PartStatus
                    </p>

                    <p>
                        <strong>From Location:</strong>
                        @ViewBag.LocationName
                    </p>

                    <p>
                        <strong>Last User:</strong>
                        @ViewBag.UserStamp
                    </p>

                </div>

                <hr />

                <form method="post"
                      action="@Url.Action(
                          "SaveStatus",
                          "Home")">

                    <input type="hidden"
                           name="PartNumber"
                           value="@ViewBag.PartNumber" />

                    <select id="ddlStatusCode" name="StatusCode"
                            class="form-select form-select-lg mb-3">

                        <option value="">
                            Move To Location
                        </option>

                        <option value="100">
                            100 - Request Replenish
                        </option>

                        <option value="200">
                            200 - Kanban from MFG
                        </option>

                        <option value="300">
                            300 - Stock min &lt;10 days
                        </option>

                        <option value="400">
                            400 - Location discrepancy
                        </option>

                        <option value="500">
                            500 - Check Shipment ETA
                        </option>

                        <option value="600">
                            600 - ETA Today
                        </option>

                        <option value="900">
                            900 - Replenish Completed
                        </option>

                    </select>

                    <button type="submit"
                            class="btn btn-success btn-lg w-100">

                        Save Status

                    </button>

                </form>
            }

        </div>

    </div>

</div>
<script>

    window.onload = function ()
    {
        var partTextbox =
            document.getElementById(
                "txtPartNumber");

        var statusDropdown =
            document.getElementById(
                "ddlStatusCode");

        // Default focus on scan textbox
        if (partTextbox)
        {
            partTextbox.focus();
        }

        // After successful scan,
        // move focus to status dropdown
        if (statusDropdown)
        {
            statusDropdown.focus();
        }
    };

</script>