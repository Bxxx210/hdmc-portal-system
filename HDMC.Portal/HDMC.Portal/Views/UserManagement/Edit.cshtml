@using System.Collections.Generic
@using System.Web.Mvc
@model HDMC.Portal.Models.UserManagementModel
@{
    ViewBag.Title = "Edit User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ใช้ CSS เดียวกับ Create.cshtml ทุกอย่าง */
    .form-wrapper {
        max-width: 640px;
        margin: 40px auto;
        padding: 0 24px;
    }

    .form-page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
    }

    .btn-back {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 7px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        text-decoration: none;
        transition: border-color 0.2s, color 0.2s, background 0.2s;
        font-family: 'DM Sans', sans-serif;
    }

        .btn-back:hover {
            border-color: #93c5fd;
            color: #1a56db;
            background: #eff6ff;
            text-decoration: none;
        }

    .form-page-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: #1e293b;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }

    .form-card-head {
        padding: 22px 28px;
        border-bottom: 1px solid #f1f5f9;
    }

    .form-card-eyebrow {
        font-size: 11px;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #1a56db;
        font-weight: 500;
        margin-bottom: 4px;
    }

    .form-card-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: #1e293b;
    }

    .form-card-body {
        padding: 28px;
    }

    .form-field {
        margin-bottom: 22px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: #64748b;
        font-weight: 500;
        margin-bottom: 8px;
    }

    .form-input, .form-select {
        width: 100%;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 11px 14px;
        font-size: 14px;
        color: #1e293b;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
        box-sizing: border-box;
    }

        .form-input:focus, .form-select:focus {
            border-color: #1a56db;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
        }

        .form-input:disabled {
            background: #f1f5f9;
            color: #94a3b8;
            cursor: not-allowed;
        }

    .check-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
    }

    .check-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #334155;
        cursor: pointer;
    }

        .check-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: #1a56db;
            cursor: pointer;
            flex-shrink: 0;
        }

        .check-item.all-companies {
            padding-bottom: 10px;
            border-bottom: 1px solid #e2e8f0;
            font-weight: 500;
            color: #1e293b;
        }

    .form-card-foot {
        padding: 18px 28px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #1a56db;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #fff;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        box-shadow: 0 2px 8px rgba(26,86,219,0.2);
    }

        .btn-submit:hover {
            background: #1646b8;
        }

        .btn-submit:active {
            transform: scale(0.98);
        }

    .alert-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #b91c1c;
        margin-bottom: 22px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
    }

    .toggle-label {
        font-size: 14px;
        color: #334155;
        font-weight: 500;
    }

    .toggle-switch {
        position: relative;
        width: 44px;
        height: 24px;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .toggle-slider {
        position: absolute;
        inset: 0;
        background: #cbd5e1;
        border-radius: 24px;
        cursor: pointer;
        transition: background 0.2s;
    }

        .toggle-slider:before {
            content: "";
            position: absolute;
            width: 18px;
            height: 18px;
            left: 3px;
            top: 3px;
            background: #fff;
            border-radius: 50%;
            transition: transform 0.2s;
        }

    .toggle-switch input:checked + .toggle-slider {
        background: #1a56db;
    }

        .toggle-switch input:checked + .toggle-slider:before {
            transform: translateX(20px);
        }
</style>

<div class="form-wrapper">
    <div class="form-page-header">
        <a href="@Url.Action("Index", "UserManagement")" class="btn-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6" /></svg>
            Back
        </a>
        <div class="form-page-title">Edit User</div>
    </div>

    <div class="form-card">
        <div class="form-card-head">
            <div class="form-card-eyebrow">User Management</div>
            <div class="form-card-title">@Model.UserId</div>
        </div>
        <div class="form-card-body">

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert-error">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    @ViewBag.ErrorMessage
                </div>
            }

            <form method="post" id="editForm">
                <input type="hidden" name="UserId" value="@Model.UserId" />
                <div class="form-field">
                    <label class="form-label">User ID</label>
                    <input type="text" value="@Model.UserId" class="form-input" disabled />
                </div>
                <div class="form-field">
                    <label class="form-label">User Name</label>
                    <input type="text" name="UserName" value="@Model.UserName" class="form-input" required />
                </div>
                <div class="form-field">
                    <label class="form-label">Application Access</label>
                    <div class="check-group">
                        @foreach (var app in (IEnumerable<SelectListItem>)ViewBag.Applications)
                        {
                            <label class="check-item">
                                <input type="checkbox" name="SelectedAppIds" value="@app.Value" @(app.Selected ? "checked" : string.Empty) />
                                @app.Text
                            </label>
                        }
                    </div>
                </div>
                <div class="form-field">
                    <label class="form-label">Company Access</label>
                    <div class="check-group">
                        <input type="hidden" name="IsAllCompanies" value="false" />
                        <label class="check-item all-companies">
                            <input type="checkbox" name="IsAllCompanies" value="true" id="IsAllCompanies" @(ViewBag.IsAllCompanies == true ? "checked" : string.Empty) />
                            All Companies
                        </label>
                        @foreach (var company in (IEnumerable<SelectListItem>)ViewBag.Companies)
                        {
                            <label class="check-item">
                                <input type="checkbox" name="SelectedCompanyCodes" value="@company.Value" class="company-option" id="company_@company.Value" @(company.Selected ? "checked" : string.Empty) />
                                @company.Text
                            </label>
                        }
                    </div>
                </div>
                <div class="form-field">
                    <label class="form-label">Role</label>
                    @Html.DropDownList("RoleId", (IEnumerable<SelectListItem>)ViewBag.Roles, "Select Role", new { @class = "form-select", required = "required" })
                </div>
                <div class="form-field">
                    <label class="form-label">Status</label>
                    <div class="toggle-row">
                        <span class="toggle-label">Active</span>
                        <label class="toggle-switch">
                            <input type="hidden" name="IsActive" value="false" />
                            <input type="checkbox" name="IsActive" value="true" id="IsActive" @(Model.IsActive ? "checked" : string.Empty) />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
            </form>

        </div>
        <div class="form-card-foot">
            <button type="submit" form="editForm" class="btn-submit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                Save
            </button>
        </div>
    </div>
</div>

<script>
    (function () {
        var allCompanies = document.getElementById("IsAllCompanies");
        var companyOptions = document.querySelectorAll(".company-option");
        function syncCompanyOptions() {
            for (var i = 0; i < companyOptions.length; i++) {
                companyOptions[i].disabled = allCompanies.checked;
            }
        }
        if (allCompanies) {
            allCompanies.addEventListener("change", syncCompanyOptions);
            syncCompanyOptions();
        }
    })();
</script>