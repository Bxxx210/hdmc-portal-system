@model List<HDMC.Portal.Models.CompanyModel>
@{
    ViewBag.Title = "Select Company";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        height: 100%;
        background: #f0f2f5;
        font-family: 'DM Sans', sans-serif;
    }

    .page-wrapper {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .page-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 32px;
    }

    .page-brand-mark {
        width: 40px;
        height: 40px;
        background: #1a56db;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 16px;
        color: #fff;
    }

    .page-brand-text {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 22px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #1e293b;
        line-height: 1;
    }

    .page-brand-sub {
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-top: 2px;
    }

    .page-card {
        width: 100%;
        max-width: 400px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        overflow: hidden;
    }

    .page-card-head {
        padding: 28px 32px 24px;
        border-bottom: 1px solid #f1f5f9;
    }

    .page-card-eyebrow {
        font-size: 11px;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #1a56db;
        font-weight: 500;
        margin-bottom: 6px;
    }

    .page-card-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: #1e293b;
    }

    .page-card-body {
        padding: 24px 32px 32px;
    }

    .page-card-hint {
        font-size: 13px;
        color: #94a3b8;
        margin-bottom: 20px;
    }

    .company-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .company-form {
        margin: 0;
    }

    .company-btn {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 14px 16px;
        cursor: pointer;
        text-align: left;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
        font-family: 'DM Sans', sans-serif;
    }

        .company-btn:hover {
            border-color: #1a56db;
            background: #f0f5ff;
            box-shadow: 0 0 0 3px rgba(26,86,219,0.08);
        }

        .company-btn:active {
            transform: scale(0.99);
        }

    .company-icon {
        width: 36px;
        height: 36px;
        background: #dbeafe;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .company-name {
        font-size: 15px;
        font-weight: 500;
        color: #1e293b;
        flex: 1;
    }

    .company-arrow {
        color: #94a3b8;
        flex-shrink: 0;
        transition: color 0.2s, transform 0.2s;
    }

    .company-btn:hover .company-arrow {
        color: #1a56db;
        transform: translateX(3px);
    }

    .page-footer {
        margin-top: 28px;
        font-size: 12px;
        color: #94a3b8;
    }
</style>

<div class="page-wrapper">
    <div class="page-brand">
        <div class="page-brand-mark">HD</div>
        <div>
            <div class="page-brand-text">HDMC</div>
            <div class="page-brand-sub">Industrial Portal</div>
        </div>
    </div>

    <div class="page-card">
        <div class="page-card-head">
            <div class="page-card-eyebrow">Select Workspace</div>
            <div class="page-card-title">Select Company</div>
        </div>
        <div class="page-card-body">
            <p class="page-card-hint">เลือก Company ที่ต้องการเข้าใช้งาน</p>
            <div class="company-list">
                @foreach (var item in Model)
                {
                    <form method="post"
                          action="@Url.Action("Select", "Company")"
                          class="company-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="company" value="@item.Company" />
                        <button type="submit" class="company-btn">
                            <div class="company-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a56db" stroke-width="2">
                                    <rect x="2" y="7" width="20" height="14" rx="2" />
                                    <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
                                </svg>
                            </div>
                            <span class="company-name">@item.Company</span>
                            <svg class="company-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 18l6-6-6-6" />
                            </svg>
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="page-footer">© @DateTime.Now.Year HDMC — All rights reserved</div>
</div>
