@using System.Collections.Generic
@using System.Web.Mvc
@model HDMC.Portal.Models.UserManagementModel

@{
    ViewBag.Title = "Edit User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h4>Edit User</h4>
        </div>

        <div class="card-body">

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form method="post">

                <input type="hidden"
                       name="UserId"
                       value="@Model.UserId" />

                <div class="mb-3">

                    <label>User ID</label>

                    <input type="text"
                           value="@Model.UserId"
                           class="form-control"
                           disabled />

                </div>

                <div class="mb-3">

                    <label>User Name</label>

                    <input type="text"
                           name="UserName"
                           value="@Model.UserName"
                           class="form-control"
                           required />

                </div>

                <div class="mb-3">

                    <label>Company</label>

                    @Html.DropDownList(
                        "Company",
                        (IEnumerable<SelectListItem>)ViewBag.Companies,
                        "Select Company",
                        new { @class = "form-select", required = "required" })

                </div>

                <div class="mb-3">

                    <label>Role</label>

                    @Html.DropDownList(
                        "RoleId",
                        (IEnumerable<SelectListItem>)ViewBag.Roles,
                        "Select Role",
                        new { @class = "form-select", required = "required" })

                </div>

                <div class="form-check mb-3">

                    <input type="checkbox"
                           name="IsActive"
                           value="true"
                           class="form-check-input"
                           id="IsActive"
                           @(Model.IsActive ? "checked" : string.Empty) />

                    <input type="hidden"
                           name="IsActive"
                           value="false" />

                    <label class="form-check-label"
                           for="IsActive">
                        Active
                    </label>

                </div>

                <button type="submit"
                        class="btn btn-primary">

                    Save

                </button>

                <a href="@Url.Action("Index", "UserManagement")"
                   class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>
