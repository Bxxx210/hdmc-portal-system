@using System.Collections.Generic
@using System.Web.Mvc
@model HDMC.Portal.Models.UserManagementModel

@{
    ViewBag.Title = "Create User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h4>Create User</h4>
        </div>

        <div class="card-body">

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form method="post">

                <div class="mb-3">

                    <label>User ID</label>

                    <input type="text"
                           name="UserId"
                           class="form-control"
                           required />

                </div>

                <div class="mb-3">

                    <label>User Name</label>

                    <input type="text"
                           name="UserName"
                           class="form-control"
                           required />

                </div>

                <div class="mb-3">

                    <label>Password</label>

                    <input type="password"
                           name="password"
                           class="form-control"
                           required />

                </div>

                <div class="mb-3">

                    <label>Confirm Password</label>

                    <input type="password"
                           name="confirmPassword"
                           class="form-control"
                           required />

                </div>

                <div class="mb-3">

                    <label>Application Access</label>

                    @foreach (var app in (IEnumerable<SelectListItem>)ViewBag.Applications)
                    {
                        <div class="form-check">
                            <input type="checkbox"
                                   name="SelectedAppIds"
                                   value="@app.Value"
                                   class="form-check-input"
                                   id="app_@app.Value"
                                   @(app.Selected ? "checked" : string.Empty) />

                            <label class="form-check-label"
                                   for="app_@app.Value">
                                @app.Text
                            </label>
                        </div>
                    }

                </div>

                <div class="mb-3">

                    <label>Company Access</label>

                    <input type="hidden"
                           name="IsAllCompanies"
                           value="false" />

                    <div class="form-check mb-2">
                        <input type="checkbox"
                               name="IsAllCompanies"
                               value="true"
                               class="form-check-input"
                               id="IsAllCompanies"
                               @(ViewBag.IsAllCompanies == true ? "checked" : string.Empty) />

                        <label class="form-check-label"
                               for="IsAllCompanies">
                            All Companies
                        </label>
                    </div>

                    @foreach (var company in (IEnumerable<SelectListItem>)ViewBag.Companies)
                    {
                        <div class="form-check">
                            <input type="checkbox"
                                   name="SelectedCompanyCodes"
                                   value="@company.Value"
                                   class="form-check-input company-option"
                                   id="company_@company.Value"
                                   @(company.Selected ? "checked" : string.Empty) />

                            <label class="form-check-label"
                                   for="company_@company.Value">
                                @company.Text
                            </label>
                        </div>
                    }

                </div>

                <div class="mb-3">

                    <label>Role</label>

                    @Html.DropDownList(
                        "RoleId",
                        (IEnumerable<SelectListItem>)ViewBag.Roles,
                        "Select Role",
                        new { @class = "form-select", required = "required" })

                </div>

                <button type="submit"
                        class="btn btn-primary">

                    Create User

                </button>

            </form>

        </div>

    </div>

</div>

<script>
    (function () {
        var allCompanies =
            document.getElementById("IsAllCompanies");

        var companyOptions =
            document.querySelectorAll(".company-option");

        function syncCompanyOptions() {
            for (var i = 0; i < companyOptions.length; i++) {
                companyOptions[i].disabled = allCompanies.checked;
            }
        }

        if (allCompanies) {
            allCompanies.addEventListener("change", syncCompanyOptions);
            syncCompanyOptions();
        }
    })();
</script>
